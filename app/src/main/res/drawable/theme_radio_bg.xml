<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/theme_radio_bg.xml
     Background for the Light / System / Dark theme RadioButtons.
     Uses state_checked so the selected button gets a filled primary-container look. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Checked state — filled primary container with rounded corners -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/md_theme_primary" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Unchecked / default state — outlined -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/md_theme_surfaceContainerLowest" />
            <stroke
                android:width="1dp"
                android:color="@color/md_theme_outline" />
            <corners android:radius="8dp" />
        </shape>
    </item>

</selector>