<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_nav_menu.xml
    5 main destinations. Browse/Category moved to side drawer.
    Map promoted to bottom nav as required by the project spec (Google Map requirement).
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:id="@+id/bottom_nav_home"
        android:icon="@drawable/home_24px"
        android:title="Home" />

    <!-- Map — replaces Browse. Browse is still accessible from side drawer + home grid -->
    <item
        android:id="@+id/bottom_nav_map"
        android:icon="@drawable/explore_nearby_24px"
        android:title="Map" />

    <item
        android:id="@+id/bottom_nav_cart"
        android:icon="@drawable/local_mall_24px"
        android:title="Cart" />

    <item
        android:id="@+id/bottom_nav_orders"
        android:icon="@drawable/receipt_24px"
        android:title="Orders" />

    <item
        android:id="@+id/bottom_nav_profile"
        android:icon="@drawable/account_circle_24px"
        android:title="Profile" />

</menu>