<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_about.xml — BookLoop About page.
    Uses the splash_animation.json Lottie file (already in res/raw/).
    Warm brown brand theme, card-based layout, fully beautiful.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ── Hero Banner ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/md_theme_primary"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="36dp"
            android:paddingBottom="36dp">

            <!-- Lottie animation — uses the book animation from splash_animation.json
                 which is already in your res/raw/ folder. No download needed! -->
            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/about_lottie"
                android:layout_width="500dp"
                android:layout_height="500dp"
                app:lottie_rawRes="@raw/aboutlogo"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="serif"
                android:text="BookLoop"
                android:textColor="@color/md_theme_onPrimary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/app_tagline"
                android:textColor="#CCffffff"
                android:textSize="14sp"
                android:letterSpacing="0.06" />

            <!-- Version pill -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@color/md_theme_primaryContainer"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="Version 1.0.0"
                android:textColor="@color/md_theme_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ── What is BookLoop ──────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/about_card_what"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">



                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="About BookLoop"
                        android:textColor="@color/md_theme_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/md_theme_outlineVariant" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.6"
                    android:text="BookLoop is a mobile book rental platform built for students and readers in Sri Lanka. Instead of buying books you may only read once, rent them for a few affordable weeks — saving money and reducing waste."
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingMultiplier="1.6"
                    android:text="Browse thousands of titles across Fiction, Non-Fiction, Educational, and more. Rent for 1 to 4 weeks, and we deliver to your doorstep in Sri Lanka."
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── How It Works ──────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/about_card_how"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="How It Works"
                        android:textColor="@color/md_theme_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/md_theme_outlineVariant" />

                <!-- Step 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/md_theme_primaryContainer"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/md_theme_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Browse &amp; Pick"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Search by genre, title, or author."
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Step 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/md_theme_primaryContainer"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@color/md_theme_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose Rental Duration"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select 1–4 weeks. Pay per week."
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Step 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/md_theme_primaryContainer"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/md_theme_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="We Deliver"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Books arrive at your door within 1–2 days."
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Step 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/md_theme_primaryContainer"
                        android:gravity="center"
                        android:text="4"
                        android:textColor="@color/md_theme_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Return &amp; Loop"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Return when done and rent your next book."
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp" />

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Tech Stack (good for viva!) ─────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/about_card_tech"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/md_theme_primaryContainer"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="  Built With"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/md_theme_surfaceContainerLowest"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text=" Java"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View android:layout_width="8dp" android:layout_height="1dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/md_theme_surfaceContainerLowest"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="  Firebase"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/md_theme_surfaceContainerLowest"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text="  Google Maps"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <View android:layout_width="8dp" android:layout_height="1dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/md_theme_surfaceContainerLowest"
                        android:gravity="center"
                        android:padding="10dp"
                        android:text=" Material 3"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Contact ───────────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/about_card_contact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text=" Contact"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="  support@bookloop.lk"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="  +94 11 234 5678"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Colombo, Sri Lanka"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="14sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Footer ────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Built as a Mobile App Development assignment"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="JIAT · 2026 · @string/app_copy"
                android:textColor="@color/md_theme_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>