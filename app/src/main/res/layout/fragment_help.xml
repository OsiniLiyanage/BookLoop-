<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_help.xml
    Help & Support page for BookLoop.
    Contains: FAQs section, contact options (email, phone), and a feedback note.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Page header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Help &amp; Support"
            android:textColor="@color/md_theme_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="We're here to help you with BookLoop"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="14sp" />

        <!-- ── Contact Us card ─────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 Contact Us"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- Call button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/help_btn_call"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Call Support: +94 77 123 4567"
                    android:textSize="14sp"
                    app:backgroundTint="@color/md_theme_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/contact_support_24px"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp" />

                <!-- Email button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/help_btn_email"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Email: support@bookloop.lk"
                    android:textSize="14sp"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── FAQ Section ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Frequently Asked Questions"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- FAQ 1 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/md_theme_surfaceContainerLow"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How does BookLoop renting work?"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Browse books, select the number of weeks you want to rent, and add to cart. After checkout, we deliver the book to your address. Return it by the due date to avoid late fees."
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FAQ 2 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/md_theme_surfaceContainerLow"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How do I add a book to my Wishlist?"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Open any book's detail page and tap the heart (♡) icon. The book is saved to your Wishlist instantly — even without internet, because it's stored on your device. Open the Wishlist from the side menu to see your saved books."
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FAQ 3 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/md_theme_surfaceContainerLow"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Can I move a wishlist book to my cart?"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Yes! In your Wishlist, each book has an &quot;Add to Cart&quot; button. Tapping it adds the book to your rental cart and removes it from your wishlist automatically."
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FAQ 4 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/md_theme_surfaceContainerLow"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How do I track my orders?"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Tap the 'Orders' tab in the bottom navigation bar. You can see all your active and past rentals, their status, and due dates."
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FAQ 5 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/md_theme_surfaceContainerLow"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Why did I receive a reminder notification?"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="BookLoop sends you automatic reminders when a book you've rented is due back soon. These notifications work even when the app is closed, using Android's background task system."
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bottom spacing -->
        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

    </LinearLayout>

</ScrollView>
