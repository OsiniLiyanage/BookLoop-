<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    tools:context=".fragment.ProductDetailsFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/product_details_bottom_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== IMAGE SLIDER ===== -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/product_image_slider"
                android:layout_width="match_parent"
                android:layout_height="320dp" />

            <com.tbuonomo.viewpagerdotsindicator.WormDotsIndicator
                android:id="@+id/dotsIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                app:dotsColor="@color/md_theme_secondary"
                app:dotsCornerRadius="8dp"
                app:dotsSize="16dp"
                app:dotsSpacing="4dp"
                app:dotsStrokeColor="@color/md_theme_primary"
                app:dotsStrokeWidth="2dp" />

            <!-- ===== TITLE + AUTHOR + RATING CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/product_details_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Book Title"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/product_details_author"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="by Author Name"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/md_theme_outlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <RatingBar
                            android:id="@+id/product_details_rating"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:rating="4.5" />

                        <TextView
                            android:id="@+id/product_details_rating_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="4.5"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/product_details_status_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/badge_available"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp"
                            android:text="Available"
                            android:textColor="@color/md_theme_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/product_details_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="LKR 500/week"
                        android:textColor="@color/md_theme_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== RENTAL DURATION + COPIES CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- - ROW 1: Rental Duration header + days label - -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rental Duration"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <!-- Auto-updates: "7 days", "14 days" etc. -->
                        <TextView
                            android:id="@+id/product_details_total_days"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7 days"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- - ROW 2: [−]  1 weeks  [+]   |   LKR 500 total - -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- MINUS weeks — uses remove_24 drawable -->
                        <ImageView
                            android:id="@+id/product_details_btn_minus"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/badge_available"
                            android:padding="8dp"
                            android:src="@drawable/remove_24px" />

                        <!-- Weeks display -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp">

                            <TextView
                                android:id="@+id/product_details_quantity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textAlignment="center"
                                android:textColor="@color/md_theme_primary"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="weeks"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <!-- PLUS weeks — uses add_24 drawable -->
                        <ImageView
                            android:id="@+id/product_details_btn_plus"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/badge_available"
                            android:padding="8dp"
                            android:src="@drawable/add_24px" />

                        <!-- Vertical divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <!-- Total rental cost (weeks × price) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/product_details_total_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LKR 500"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="total rental cost"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/md_theme_outlineVariant" />

                    <!-- - ROW 3: No. of Copies stepper + available count - -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No. of Copies"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- MINUS copies -->
                        <ImageView
                            android:id="@+id/product_details_btn_copies_minus"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/badge_available"
                            android:padding="7dp"
                            android:src="@drawable/remove_24px" />

                        <TextView
                            android:id="@+id/product_details_copies"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textAlignment="center"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- PLUS copies -->
                        <ImageView
                            android:id="@+id/product_details_btn_copies_plus"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/badge_available"
                            android:padding="7dp"
                            android:src="@drawable/add_24px" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="of"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/product_details_avb_qty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textColor="@color/md_theme_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="available"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== BOOK CONDITION / ATTRIBUTES CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Book Details"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/product_details_attribute_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== DESCRIPTION CARD ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/md_theme_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="About this Book"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/product_details_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingMultiplier="1.5"
                        android:text="Description..."
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== SECTION 1: More in this Category ===== -->
            <include
                android:id="@+id/product_details_same_category_section"
                layout="@layout/item_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- ===== SECTION 2: More by same Author ===== -->
            <include
                android:id="@+id/product_details_same_author_section"
                layout="@layout/item_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- ===== SECTION 3: Top Rated Books ===== -->
            <include
                android:id="@+id/product_details_top_rated_section"
                layout="@layout/item_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===================== BOTTOM ACTION BAR ===================== -->
    <LinearLayout
        android:id="@+id/product_details_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/md_theme_surfaceContainerLowest"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/product_details_btn_wishlist"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="12dp"
            app:icon="@drawable/bookmark_heart_24px"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/product_details_btn_add_cart"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Add to Cart"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/product_details_btn_buy_now"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Rent Now"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="@color/md_theme_primary"
            app:cornerRadius="12dp" />

    </LinearLayout>

</RelativeLayout>