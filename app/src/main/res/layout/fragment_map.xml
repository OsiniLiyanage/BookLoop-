<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_map.xml — BookLoop "Find Us Near You" map screen.
     Layout: floating info card on top, Google Map fills the rest of the screen. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- The map fills the entire screen behind the card -->
    <!-- WHY fragment tag: SupportMapFragment needs to be declared here so the
         Maps SDK can attach the map surface to this exact container.
         We use getChildFragmentManager() in Java to find it (NOT getSupportFragmentManager). -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Floating card at the top — tells user what this screen is for -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/md_theme_outlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- BookLoop pin icon -->
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/explore_nearby_24px"
                app:tint="@color/md_theme_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Find BookLoop Near You"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Long-press anywhere to get directions"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Location permission status indicator -->
            <TextView
                android:id="@+id/map_location_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_available"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:text="📍 Live"
                android:textColor="@color/md_theme_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom legend card — explains what markers mean -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/md_theme_outlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- Nearest pickup label -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚 Pickup/Return Points"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/map_nearest_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Tap a marker to see details"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Clear route button — hidden until a route is drawn -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/map_btn_clear_route"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear Route"
                android:visibility="gone"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>