<?xml version="1.0" encoding="utf-8"?>
<!-- item_checkout_book.xml — one row in the checkout order summary list.
     Shows: book title | copies × weeks | subtotal price
     Used by: CheckoutAdapter inside CheckoutFragment -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Book title + rental detail (left side, takes all available space) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Book title e.g. "Harry Potter" -->
        <TextView
            android:id="@+id/checkout_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Book Title"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- e.g. "2 copies × 3 weeks" -->
        <TextView
            android:id="@+id/checkout_item_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="1 copy × 1 week"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Subtotal for this item (right side) -->
    <TextView
        android:id="@+id/checkout_item_subtotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="LKR 500"
        android:textColor="@color/md_theme_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>