<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_home.xml
    Home screen layout:
    1. Auto-scrolling banner slider (ViewPager2 + dots)
    2. Section: Browse Categories (4 items + "See All" arrow)
    3. Section: Top Rated Books (horizontal scroll)
    4. Section: New Arrivals (horizontal scroll)
    5. Section: Recently Viewed (horizontal scroll, SQLite)
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Banner Slider ──────────────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="8dp">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/home_banner_slider"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Dots indicator — attaches to ViewPager2 in Java -->
            <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
                android:id="@+id/home_banner_dots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="10dp"
                app:dotsColor="@color/md_theme_onPrimary"
                app:dotsSize="7dp"
                app:dotsSpacing="4dp"
                app:selectedDotColor="@color/md_theme_primary" />

        </FrameLayout>

        <!-- ── Browse by Genre section ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp">

            <!-- Row: "Browse by Genre" title + "See All" button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Browse by Genre"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- Tapping this goes to CategoryFragment -->
                <TextView
                    android:id="@+id/home_btn_see_all_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:text="See All →"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- 2-column grid for first 4 categories — uses a GridLayoutManager(2) RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/home_category_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

        <!-- ── Top Rated Books section ──────────────────────────────────── -->
        <include
            android:id="@+id/home_top_rated_section"
            layout="@layout/item_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <!-- ── New Arrivals section ──────────────────────────────────────── -->
        <include
            android:id="@+id/home_new_arrivals_section"
            layout="@layout/item_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <!-- ── Recently Viewed section (from SQLite) ──────────────────────── -->
        <include
            android:id="@+id/home_recently_viewed_section"
            layout="@layout/item_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <include
            android:id="@+id/home_search_results_section"
            layout="@layout/item_section"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>