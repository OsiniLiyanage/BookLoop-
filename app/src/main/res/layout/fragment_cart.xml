<?xml version="1.0" encoding="utf-8"?>
<!-- Cart Fragment layout — full screen, no bottom nav, scroll items, sticky summary at bottom -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:orientation="vertical"
    tools:context=".fragment.CartFragment">

    <!-- ── Header bar with back button and title ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_surfaceContainerLowest"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Back button — navigates back to Home -->
        <ImageView
            android:id="@+id/cart_btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/badge_available"
            android:padding="8dp"
            android:src="@drawable/arrow_back_24px" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="My Rental Cart"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Item count badge -->
        <TextView
            android:id="@+id/cart_item_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_available"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="0 items"
            android:textColor="@color/md_theme_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ── Scrollable cart items list ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/cart_cart_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="10dp"
        android:paddingBottom="10dp" />

    <!-- ── Empty cart message (hidden when items exist) ── -->
    <LinearLayout
        android:id="@+id/cart_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your cart is empty"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Browse books and add them to rent"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ── Sticky bottom summary card ── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Summary rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Rental Amount"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/cart_text_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LKR 0.00"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Proceed button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/cart_btn_proceed"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Proceed to Checkout"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/md_theme_primary"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>