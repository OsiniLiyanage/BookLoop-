<?xml version="1.0" encoding="utf-8"?>
<!-- Single cart item card — shows book cover, title, author, condition, weeks stepper, price -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/md_theme_outlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── TOP ROW: Book cover + info ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Book cover — portrait rectangle -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="80dp"
                android:layout_height="110dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <ImageView
                    android:id="@+id/item_cart_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Book info column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Title -->
                <TextView
                    android:id="@+id/item_cart_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Book Title"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Author -->
                <TextView
                    android:id="@+id/item_cart_author"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="by Author"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="12sp" />

                <!-- Condition badge — shows selected condition e.g. "Good" -->
                <TextView
                    android:id="@+id/item_cart_condition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/badge_available"
                    android:paddingStart="8dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="3dp"
                    android:text="Condition: Good"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="11sp" />

                <!-- Price per week -->
                <TextView
                    android:id="@+id/item_cart_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="LKR 500/week"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Delete button — top right -->
            <ImageView
                android:id="@+id/item_cart_remove"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top"
                android:src="@drawable/delete_forever_24px" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@color/md_theme_outlineVariant" />

        <!-- ── BOTTOM ROW: Weeks stepper + Copies stepper + Item total ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- WEEKS stepper -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weeks"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/item_cart_btn_weeks_minus"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/badge_available"
                        android:padding="5dp"
                        android:src="@drawable/remove_24px" />

                    <TextView
                        android:id="@+id/item_cart_weeks"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textAlignment="center"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/item_cart_btn_weeks_plus"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/badge_available"
                        android:padding="5dp"
                        android:src="@drawable/add_24px" />

                </LinearLayout>
            </LinearLayout>

            <!-- Vertical divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@color/md_theme_outlineVariant" />

            <!-- COPIES stepper -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copies"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/item_cart_btn_minus"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/badge_available"
                        android:padding="5dp"
                        android:src="@drawable/remove_24px" />

                    <TextView
                        android:id="@+id/item_cart_quantity"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textAlignment="center"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/item_cart_btn_plus"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/badge_available"
                        android:padding="5dp"
                        android:src="@drawable/add_24px" />

                </LinearLayout>
            </LinearLayout>

            <!-- Vertical divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@color/md_theme_outlineVariant" />

            <!-- Item subtotal (weeks × copies × price) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subtotal"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/item_cart_subtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="LKR 500"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>