<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_sign_up.xml — matches new SignIn design style.
    ALL ViewBinding IDs are identical to the original so SignUpActivity.java
    needs ZERO changes:
      signup_input_name, signup_input_email, signup_input_password,
      signup_input_retype_password, signup_btn_signup, signup_btn_signin

    Lottie animation: put your signup animation JSON at res/raw/signup_animation.json
    (download any "register / create account" animation from lottiefiles.com)
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/md_theme_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- ── App name ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="BookLoop"
            android:textColor="@color/md_theme_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:letterSpacing="0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/app_tagline"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="12sp"
            android:letterSpacing="0.04" />


        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/signupAnimationView"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginTop="8dp"
            app:lottie_rawRes="@raw/signup_animation"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_speed="1.0" />

        <!-- ── Heading ────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/signup_welcome"
            android:textColor="@color/md_theme_onBackground"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Create your free account"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="14sp" />

        <!-- ── Full Name ──────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/md_theme_primary"
            app:hintTextColor="@color/md_theme_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/signup_input_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/signup_name_label"
                android:inputType="textPersonName"
                android:textSize="16sp"
                android:textColor="@color/md_theme_onSurface"
                android:textColorHint="@color/md_theme_outline" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Email ──────────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/md_theme_primary"
            app:hintTextColor="@color/md_theme_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/signup_input_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/signup_email_label"
                android:inputType="textEmailAddress"
                android:textSize="16sp"
                android:textColor="@color/md_theme_onSurface"
                android:textColorHint="@color/md_theme_outline" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Password ───────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:endIconMode="password_toggle"
            app:boxStrokeColor="@color/md_theme_primary"
            app:hintTextColor="@color/md_theme_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/signup_input_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/signup_password_label"
                android:inputType="textPassword"
                android:textSize="16sp"
                android:textColor="@color/md_theme_onSurface"
                android:textColorHint="@color/md_theme_outline" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Confirm Password ───────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:endIconMode="password_toggle"
            app:boxStrokeColor="@color/md_theme_primary"
            app:hintTextColor="@color/md_theme_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/signup_input_retype_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/signup_confirm_password_label"
                android:inputType="textPassword"
                android:textSize="16sp"
                android:textColor="@color/md_theme_onSurface"
                android:textColorHint="@color/md_theme_outline" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:text="@string/signup_password_hint_text"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="11sp" />

        <!-- ── Create Account button ──────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/signup_btn_signup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/signup_button"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onPrimary"
            app:cornerRadius="8dp"
            app:backgroundTint="@color/md_theme_primary" />

        <!-- ── Progress bar ───────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/signup_progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:indeterminateTint="@color/md_theme_primary" />

        <!-- ── Already have account link ─────────────────────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/signup_have_account"
                android:textSize="14sp"
                android:textColor="@color/md_theme_onSurfaceVariant" />

            <TextView
                android:id="@+id/signup_btn_signin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/signup_sign_in"
                android:textSize="14sp"
                android:textColor="@color/md_theme_primary"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>