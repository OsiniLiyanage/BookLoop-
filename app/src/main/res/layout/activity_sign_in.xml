<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_sign_in.xml — dark-mode-safe redesign
    ALL colors use @color/md_theme_* or ?attr/colorSurface so both light and
    dark themes work without any change.
    Removed: Forgot Password link
    Added:   "BookLoop" title at top, larger Lottie animation
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/md_theme_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- ── App name ───────────────────────────────────────────── -->


        <!-- ── Lottie login animation (larger) ───────────────────── -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/loginAnimationView"
            android:layout_width="400dp"
            android:layout_height="400dp"
            app:lottie_rawRes="@raw/login_animation"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_speed="1.0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="BookLoop"
            android:textColor="@color/md_theme_primary"
            android:textSize="40sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:letterSpacing="0.03" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/app_tagline"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="12sp"
            android:letterSpacing="0.04" />

        <!-- ── Welcome text ──────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign in to continue"
            android:textColor="@color/md_theme_onBackground"
            android:textSize="24sp"
            android:textStyle="bold" />



        <!-- ── Email input ────────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/md_theme_primary"
            app:startIconDrawable="@drawable/mail_24px"
            app:hintTextColor="@color/md_theme_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:textSize="16sp"
                android:textColor="@color/md_theme_onSurface"
                android:textColorHint="@color/md_theme_outline" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Password input ────────────────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:endIconMode="password_toggle"
            app:startIconDrawable="@drawable/key_vertical_24px"
            app:boxStrokeColor="@color/md_theme_primary"
            app:hintTextColor="@color/md_theme_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                android:inputType="textPassword"
                android:textSize="16sp"
                android:textColor="@color/md_theme_onSurface"
                android:textColorHint="@color/md_theme_outline" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Sign In button ─────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/signInButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="Sign In"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onPrimary"
            app:cornerRadius="8dp"
            app:backgroundTint="@color/md_theme_primary" />

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/forgotPasswordTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="Forgot Password?"
            android:textColor="@color/md_theme_primary"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />


        <!-- ── Progress bar ───────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:indeterminateTint="@color/md_theme_primary" />

        <!-- ── Sign Up link ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't have an account? "
                android:textSize="14sp"
                android:textColor="@color/md_theme_onSurfaceVariant" />

            <TextView
                android:id="@+id/signUpTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Up"
                android:textSize="14sp"
                android:textColor="@color/md_theme_primary"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>