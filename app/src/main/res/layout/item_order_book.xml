<?xml version="1.0" encoding="utf-8"?>
<!-- NEW — Single book row inside an order card -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Book cover thumbnail -->
    <ImageView
        android:id="@+id/order_book_image"
        android:layout_width="36dp"
        android:layout_height="50dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="Book cover" />

    <!-- Book info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/order_book_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Book Title"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/order_book_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2 copies × 3 weeks"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="11sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/order_book_subtotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="LKR 300.00"
        android:textColor="@color/md_theme_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>