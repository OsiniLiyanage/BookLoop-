<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_settings.xml — Fully updated Settings screen.

    SECTIONS:
    1. Notifications   → SwitchMaterial (SharedPreferences: boolean)
    2. Appearance      → Dark/Light/System theme toggle (SharedPreferences: String)
    3. Delivery Info   → Shows last saved delivery details (SharedPreferences read)
    4. Account         → Change Password (Firebase Auth)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:orientation="vertical">



    <!-- Lottie animation banner below the header -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/settings_lottie"
        android:layout_width="300dp"
        android:layout_height="300dp"
        app:lottie_rawRes="@raw/setting"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:scaleType="centerCrop"
        android:layout_marginTop="20dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- SECTION 1: NOTIFICATIONS                                   -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/settings_section_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="NOTIFICATIONS"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@color/md_theme_primaryContainer"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/notifications_24px"
                                app:tint="@color/md_theme_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Push Notifications"
                                android:textColor="@color/md_theme_onSurface"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Order updates &amp; return reminders"
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/settings_switch_notifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- SECTION 2: APPEARANCE — Theme Toggle                       -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/settings_section_appearance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="APPEARANCE"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Theme label row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="14dp">

                            <LinearLayout
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="@color/md_theme_primaryContainer"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/palette_24px"
                                    app:tint="@color/md_theme_primary" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="App Theme"
                                    android:textColor="@color/md_theme_onSurface"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/settings_theme_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="System default"
                                    android:textColor="@color/md_theme_onSurfaceVariant"
                                    android:textSize="12sp" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Three theme buttons: Light / System / Dark -->
                        <RadioGroup
                            android:id="@+id/settings_theme_group"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <RadioButton
                                android:id="@+id/settings_theme_light"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="☀ Light"
                                android:textSize="13sp"
                                android:button="@null"
                                android:background="@drawable/theme_radio_bg"
                                android:padding="10dp" />

                            <View
                                android:layout_width="8dp"
                                android:layout_height="1dp" />

                            <RadioButton
                                android:id="@+id/settings_theme_system"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="⚙ System"
                                android:textSize="13sp"
                                android:checked="true"
                                android:button="@null"
                                android:background="@drawable/theme_radio_bg"
                                android:padding="10dp" />

                            <View
                                android:layout_width="8dp"
                                android:layout_height="1dp" />

                            <RadioButton
                                android:id="@+id/settings_theme_dark"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="🌙 Dark"
                                android:textSize="13sp"
                                android:button="@null"
                                android:background="@drawable/theme_radio_bg"
                                android:padding="10dp" />

                        </RadioGroup>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- SECTION 3: SAVED DELIVERY INFO                             -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/settings_section_delivery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="SAVED DELIVERY INFO"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/md_theme_primaryContainer"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@color/md_theme_surfaceContainerLowest"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/explore_nearby_24px"
                                app:tint="@color/md_theme_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Last Delivery Details"
                                android:textColor="@color/md_theme_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/settings_delivery_preview"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Loading..."
                                android:textColor="@color/md_theme_onSurfaceVariant"
                                android:textSize="12sp"
                                android:lineSpacingMultiplier="1.4" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- SECTION 4: ACCOUNT — Change Password                       -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/settings_section_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="ACCOUNT"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Email row (read-only display) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <LinearLayout
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="@color/md_theme_primaryContainer"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/account_circle_24px"
                                    app:tint="@color/md_theme_primary" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Signed in as"
                                    android:textColor="@color/md_theme_onSurfaceVariant"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/settings_user_email"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Loading..."
                                    android:textColor="@color/md_theme_onSurface"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:background="@color/md_theme_outlineVariant" />

                        <!-- Current password field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/settings_til_current_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="Current Password"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:endIconMode="password_toggle"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/settings_et_current_password"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:imeOptions="actionNext" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- New password field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/settings_til_new_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="New Password"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:endIconMode="password_toggle"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/settings_et_new_password"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:imeOptions="actionNext" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Confirm new password field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/settings_til_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:hint="Confirm New Password"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:endIconMode="password_toggle"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/settings_et_confirm_password"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:imeOptions="actionDone" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Change Password button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/settings_btn_change_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Update Password"
                            android:textSize="15sp"
                            app:cornerRadius="10dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="50dp"
                android:layout_marginBottom="8dp"
                android:text="BookLoop v1.0.0 · © ONdeveloper · JIAT 2026"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="12sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>